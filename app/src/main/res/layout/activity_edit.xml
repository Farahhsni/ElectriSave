<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Custom Back Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="🔙"
                android:textSize="18sp"
                app:cornerRadius="25dp"
                android:backgroundTint="#E8D5C4"
                android:textColor="#5C3D2E" />

        </LinearLayout>

        <!-- Header Icon - CENTERED -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️"
            android:textSize="56sp"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp" />

        <!-- Title - CENTERED -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Bill"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Month Card - CENTERED -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/cardBackground"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 SELECT MONTH"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp" />

                <Spinner
                    android:id="@+id/spinnerMonth"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/spinner_background"
                    android:padding="16dp"
                    android:textSize="16sp"
                    android:popupBackground="#FFFFFF" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Unit Card - CENTERED -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 UNITS USED (kWh)"
                    android:textSize="13sp"
                    android:textColor="#A78B71"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etUnit"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:inputType="number"
                    android:hint="Enter 1 - 1000"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:textColor="#2D3E50"
                    android:textColorHint="#A78B71"
                    android:gravity="center" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Rebate Card - CENTERED -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎁 REBATE (%)"
                    android:textSize="13sp"
                    android:textColor="#A78B71"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etRebate"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:inputType="numberDecimal"
                    android:hint="Enter 0 - 5"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:textColor="#2D3E50"
                    android:textColorHint="#A78B71"
                    android:gravity="center" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Results Card - CENTERED -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            android:visibility="visible"
            app:cardBackgroundColor="#E8F4F8"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 CURRENT CALCULATION"
                    android:textSize="12sp"
                    android:textColor="#5C3D2E"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Charges"
                    android:textSize="13sp"
                    android:textColor="#A78B71"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvTotalCharges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2D3E50"
                    android:layout_marginBottom="12dp"
                    android:gravity="center" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="1dp"
                    android:background="#DDBFA8"
                    android:layout_marginVertical="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="After Rebate"
                    android:textSize="13sp"
                    android:textColor="#A78B71"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvFinalCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#C4A484"
                    android:gravity="center" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons Row - CENTERED -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                android:layout_width="130dp"
                android:layout_height="50dp"
                android:text="UPDATE"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="25dp"
                android:backgroundTint="#7EB09E"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="130dp"
                android:layout_height="50dp"
                android:text="CANCEL"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="25dp"
                android:backgroundTint="#E0A4A4"
                android:textColor="#FFFFFF"
                android:layout_marginStart="12dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>