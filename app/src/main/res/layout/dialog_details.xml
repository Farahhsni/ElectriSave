<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFF5EE"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄"
                android:textSize="38sp"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="16dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BILL DETAILS"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#C4A484"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <!-- Divider -->
            <View
                android:layout_width="150dp"
                android:layout_height="1dp"
                android:background="#C4A484"
                android:layout_marginBottom="20dp" />

            <!-- Month Row - Centered -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Month"
                    android:textSize="16sp"
                    android:textColor="#A78B71"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/detailMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="January"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5C3D2E" />

            </LinearLayout>

            <!-- Unit Row - Centered -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 Unit Used"
                    android:textSize="16sp"
                    android:textColor="#A78B71"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/detailUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150 kWh"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5C3D2E" />

            </LinearLayout>

            <!-- Total Charges Row - Centered -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Total Charges"
                    android:textSize="16sp"
                    android:textColor="#A78B71"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/detailTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RM 32.70"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5C3D2E" />

            </LinearLayout>

            <!-- Rebate Row - Centered -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎁 Rebate"
                    android:textSize="16sp"
                    android:textColor="#A78B71"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/detailRebate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5%"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5C3D2E" />

            </LinearLayout>


            <!-- Final Cost Row - Centered & Highlighted -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#E8D5C4"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Final Cost"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#C4A484"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/detailFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RM 31.07"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#5C3D2E" />

            </LinearLayout>

            <!-- Button Row: Delete and Close side by side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <!-- Delete Button (Bin Emoji) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteDetail"
                    android:layout_width="60dp"
                    android:layout_height="44dp"
                    android:text="🗑️"
                    android:textSize="18sp"
                    app:cornerRadius="22dp"
                    android:backgroundTint="#E8D5C4"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="10dp"/>

                <!-- Close Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCloseDetail"
                    android:layout_width="100dp"
                    android:layout_height="44dp"
                    android:text="CLOSE"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="22dp"
                    android:backgroundTint="#C4A484"
                    android:layout_marginBottom="10dp"/>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>